# Caddyfile example for Static Site CMS (Caddy v2)
#
# Rename to "Caddyfile" or paste this site block into your existing Caddyfile.
# Replace "yoursite.com" and "/var/www/yoursite" with your domain and document root.
#
# Common PHP-FPM socket paths:
#   Ubuntu / Debian default   unix//run/php/php8.3-fpm.sock
#   CloudPanel                unix//run/php/php8.3-fpm.sock   (adjust PHP version)
#   RunCloud                  unix//var/run/runcloud/php8.3-fpm-<site>.sock
#   HestiaCP                  unix//run/php/php8.3-fpm.sock   (or tcp/127.0.0.1:9000)
#   Webmin / Virtualmin       unix//run/php/php8.3-fpm.sock
#   DirectAdmin               unix//run/php-fpm/php83.sock

yoursite.com {
    root * /var/www/yoursite

    # Match upload limits in .user.ini
    request_body {
        max_size 16MB
    }

    route {
        # Block PHP/script execution inside the uploads directory
        @exec_in_uploads path_regexp ^/data/uploads/.*\.(php[0-9]?|phtml|phar|pl|cgi)$
        respond @exec_in_uploads 403

        # Block every path under data/ EXCEPT data/uploads/
        @blocked_data {
            path /data/*
            not path /data/uploads/*
        }
        respond @blocked_data 403

        # PHP via PHP-FPM — adjust socket path to match your server (see header)
        php_fastcgi unix//run/php/php8.3-fpm.sock

        file_server
    }
}
