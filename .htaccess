# Protect sensitive backend directories from direct web access
<IfModule mod_rewrite.c>
  RewriteEngine On

  # /admin and /admin/ → admin/index.php (makes /admin a clean entry point)
  RewriteRule ^admin/?$ /admin/index.php [L]

  # Block all of data/ except data/uploads/ (images must be web-accessible)
  RewriteRule ^data/(?!uploads/) - [F,L]
</IfModule>

# Disable directory listings
Options -Indexes

# Raise PHP upload limits for image handling (works with mod_php on shared cPanel hosting)
<IfModule mod_php8.c>
  php_value upload_max_filesize 10M
  php_value post_max_size 16M
</IfModule>
<IfModule mod_php7.c>
  php_value upload_max_filesize 10M
  php_value post_max_size 16M
</IfModule>
